# Copy to .env.local for local dev. Set the same keys in Vercel (Production / Preview).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Required for admin login and server-side API routes (never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public site URL (no trailing slash). Used when the server calls its own API (e.g. notifications).
# Production example: https://mysurro.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
